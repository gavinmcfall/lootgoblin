#!/usr/bin/env bash
# Block commits whose message mentions Claude or Anthropic.
set -eu
msg_file="$1"
if grep -qiE '(claude|anthropic)' "$msg_file"; then
  echo "commit-msg hook: message contains 'claude' or 'anthropic' — blocked." >&2
  echo "Edit the message and try again." >&2
  exit 1
fi
exit 0
